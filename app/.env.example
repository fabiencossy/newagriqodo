# Supabase — instance auto-hébergée VPS Infomaniak (CH strict)
# Remplir avec les valeurs réelles dans .env.local (jamais commit).
VITE_SUPABASE_URL=https://supabase.newagri.qodo.ch
VITE_SUPABASE_ANON_KEY=replace-with-anon-key

# Inscription publique. true (défaut) = bloquée côté UI (le serveur doit
# aussi avoir DISABLE_SIGNUP=true, cf. infra/supabase/.env). Comptes
# créés par invitation uniquement (recommandé pour la prod B2B agricole).
VITE_DISABLE_SIGNUP=true
