# ============================================================================
# Supabase self-host — .env.example
# ============================================================================
# Copier en .env (jamais commit) et remplir TOUS les secrets.
# Générer chaque secret avec : openssl rand -hex 64
# JWT_SECRET (32 chars min) : openssl rand -base64 32
# ============================================================================

# --- URLs publiques ---
SUPABASE_PUBLIC_URL=https://supabase.newagri.qodo.ch
APP_PUBLIC_URL=https://newagri.qodo.ch
ADDITIONAL_REDIRECT_URLS=https://newagri.qodo.ch/login,https://newagri.qodo.ch/reset-password,http://localhost:5173,http://localhost:5173/login,http://localhost:5173/reset-password

# --- Secrets principaux ---
POSTGRES_PASSWORD=replace-with-strong-password
JWT_SECRET=replace-with-base64-32-chars-minimum

# Clés API — à générer avec supabase/jwt (https://supabase.com/docs/guides/self-hosting#api-keys)
# Ou utiliser https://jwt.io avec payload {"role":"anon","iss":"supabase","iat":...,"exp":...}
SUPABASE_ANON_KEY=replace-with-anon-jwt
SUPABASE_SERVICE_KEY=replace-with-service-jwt

# --- Realtime ---
REALTIME_ENC_KEY=replace-with-32-byte-key
REALTIME_SECRET_KEY_BASE=replace-with-64-byte-secret

# --- Sécurité ---
# Inscription publique : true = bloquée (invitation only, recommandé pour la prod).
# Passer à 'false' uniquement pendant un beta public protégé par captcha.
DISABLE_SIGNUP=true

# --- SMTP (Resend — sprint S3) ---
SMTP_ADMIN_EMAIL=admin@qodo.ch
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=replace-with-resend-api-key
SMTP_SENDER_NAME=NewagriQodo
