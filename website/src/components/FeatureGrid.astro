---
interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  title: string;
  subtitle?: string;
  features: Feature[];
}

const { title, subtitle, features } = Astro.props;
---

<section class="border-t border-(--color-border) bg-(--color-bg) px-4 py-16 sm:px-6 sm:py-20">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="m-0 text-3xl leading-tight font-bold tracking-tight sm:text-4xl">{title}</h2>
      {subtitle && <p class="m-0 mt-3 text-base text-(--color-muted)">{subtitle}</p>}
    </div>

    <div class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="rounded-(--radius-lg) border border-(--color-border) bg-(--color-surface) p-6 shadow-(--shadow-card)">
            <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-(--radius) bg-(--color-primary)/10 text-(--color-primary)" set:html={f.icon} />
            <h3 class="m-0 text-base font-semibold">{f.title}</h3>
            <p class="m-0 mt-2 text-sm text-(--color-muted)">{f.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
