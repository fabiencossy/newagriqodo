---
const navItems = [
  { label: 'Fonctionnalités', href: '/fonctionnalites' },
  { label: 'Tarifs', href: '/tarifs' },
  { label: 'Contact', href: '/contact' },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full border-b border-(--color-border) bg-(--color-surface)/95 backdrop-blur-sm">
  <div class="mx-auto flex h-16 max-w-6xl items-center gap-3 px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 font-semibold">
      <span class="text-lg tracking-tight">
        <span class="text-(--color-primary)">Newagri</span>Qodo
      </span>
    </a>

    <nav class="ml-auto hidden items-center gap-1 md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={[
              'inline-flex h-10 items-center rounded-(--radius-sm) px-3 text-sm font-medium transition-colors',
              currentPath === item.href
                ? 'text-(--color-primary)'
                : 'text-(--color-text) hover:text-(--color-primary)',
            ].join(' ')}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href="https://newagri.qodo.ch/login"
      class="ml-auto inline-flex h-10 items-center gap-2 rounded-(--radius) border border-(--color-primary) bg-(--color-primary) px-4 text-sm font-semibold text-white hover:bg-(--color-primary-hover) md:ml-0"
    >
      Essayer la démo
      <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true">
        <path d="M8 5v14l11-7z" />
      </svg>
    </a>
  </div>
</header>
