---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeatureSwitchable from '../components/FeatureSwitchable.astro';
import CTASection from '../components/CTASection.astro';

const APP_URL = 'https://newagri.qodo.ch/login';
---

<BaseLayout
  title="Fonctionnalités"
  description="Découvrez ce que fait NewagriQodo : voir vos parcelles, noter vos interventions, suivre votre carnet des champs. Sur téléphone et au bureau."
>
  <section class="border-b border-(--color-border) bg-gradient-to-b from-(--color-bg) to-(--color-surface)/40 px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-(--radius-pill) bg-(--color-primary)/10 px-3 py-1 text-xs font-semibold tracking-wider text-(--color-primary) uppercase">
        Ce que ça fait
      </span>
      <h1 class="m-0 mt-4 text-4xl leading-tight font-extrabold tracking-tight sm:text-5xl">
        Simple. Sur tous vos écrans.
      </h1>
      <p class="m-0 mt-4 text-lg text-(--color-muted)">
        Sur chaque fonctionnalité, vous pouvez voir à quoi ça ressemble depuis votre
        <strong class="text-(--color-text)">ordinateur</strong> ou votre
        <strong class="text-(--color-text)">téléphone</strong>. Cliquez sur les boutons à côté
        des images pour basculer.
      </p>
    </div>
  </section>

  <FeatureSwitchable
    id="cartographie"
    eyebrow="Cartographie"
    title="Toutes vos parcelles sur une carte"
    description="Vue satellite suisse. Vous voyez l'ensemble de votre exploitation d'un coup d'œil. Chaque parcelle est colorée selon la culture en place."
    bullets={[
      'Vue satellite de <strong>qualité suisse</strong>',
      "Couleurs <strong>automatiques</strong> selon ce qui pousse",
      'Cliquez sur une parcelle pour voir ses détails',
      'Importez vos parcelles depuis <strong>GELAN</strong> ou <strong>Acorda</strong>',
    ]}
    desktop={{
      src: '/screenshots/01_Hero/H3_Hero_Desktop_-_Panel__droite.png',
      alt: 'Carte des parcelles avec panneau de détail (ordinateur)',
    }}
    mobile={{
      src: '/screenshots/01_Hero/H4_Hero_Mobile_-_Bottom_sheet.png',
      alt: 'Carte des parcelles avec panneau coulissant (téléphone)',
    }}
  />

  {/* SECTION "SAISIE FACILE" — DÉSACTIVÉE TEMPORAIREMENT
   * En attente des vrais screenshots du formulaire InterventionForm en cours de
   * remplissage (catégorie sélectionnée, ProductPicker ouvert, champs visibles).
   * Les fichiers C4 / F1-F4 actuellement présents sont des captures de la carte
   * mal nommées au moment de la prise. À retaker côté PO. */}

  <FeatureSwitchable
    id="fiche-parcelle"
    eyebrow="Fiche parcelle"
    title="Toute l'histoire d'une parcelle, au même endroit"
    description="En ouvrant une parcelle, vous voyez immédiatement la culture en place, les dernières interventions, le résumé de la fumure et une mini-carte. Tout est rangé par onglets clairs."
    bullets={[
      "Onglets : <strong>Aperçu, Carnet, Assolement, Statistiques, Carte</strong>",
      "Un <strong>résumé visuel</strong> dès l\'ouverture",
      '<strong>Mini-carte</strong> de la parcelle directement intégrée',
      "Lien pour <strong>aller au champ</strong> via Google Maps",
    ]}
    desktop={{
      src: '/screenshots/03_DetailParcelle/D1_Detail_-_Aperu.png',
      alt: "Fiche détaillée d'une parcelle (ordinateur)",
    }}
    mobile={{
      src: '/screenshots/03_DetailParcelle/D2_Detail_Mobile_-_Aperu.png',
      alt: "Fiche détaillée d'une parcelle (téléphone)",
    }}
  />

  <FeatureSwitchable
    id="carnet-des-champs"
    eyebrow="Carnet des champs"
    title="Toujours en règle, sans efforts"
    description="Toutes vos interventions enregistrées au bon format. Quand un contrôleur passe ou que vous devez exporter pour les autorités, tout est prêt."
    reverse
    bullets={[
      'Liste complète, filtrable par <strong>date, parcelle, type</strong>',
      "Numéro d'homologation des produits enregistré automatiquement",
      "Date de récolte autorisée <strong>calculée pour vous</strong>",
      'Export <strong>PDF / Excel</strong> à tout moment',
    ]}
    desktop={{
      src: '/screenshots/04_Carnet/C1_Carnet_-_Table_interventions.png',
      alt: 'Liste des interventions du carnet (ordinateur)',
    }}
    mobile={{
      src: '/screenshots/04_Carnet/C2_Carnet_Mobile_-_Cards.png',
      alt: 'Liste des interventions du carnet (téléphone)',
    }}
  />

  <section class="border-t border-(--color-border) bg-(--color-bg) px-4 py-16 sm:px-6 sm:py-20">
    <div class="mx-auto max-w-3xl rounded-(--radius-lg) border border-(--color-border) bg-(--color-surface) p-8 text-center shadow-(--shadow-card)">
      <span class="inline-block rounded-(--radius-pill) bg-(--color-accent)/10 px-3 py-1 text-xs font-semibold tracking-wider text-(--color-accent) uppercase">
        Intégration
      </span>
      <h2 class="m-0 mt-3 text-2xl font-bold sm:text-3xl">Connecté à votre Odoo</h2>
      <p class="m-0 mt-3 text-base text-(--color-muted)">
        Si vous avez déjà <a href="https://www.odoo.com" target="_blank" rel="noopener noreferrer" class="font-medium text-(--color-primary) hover:underline">Odoo</a>
        pour la gestion de votre exploitation, NewagriQodo s'y branche directement.
        Pas de double saisie : ce que vous notez ici remonte automatiquement dans votre Odoo.
      </p>
    </div>
  </section>

  <CTASection
    title="Essayez l'app maintenant"
    subtitle="Pas d'inscription. Vous arrivez directement sur un vrai domaine, avec de vraies parcelles. En 30 secondes."
    ctaPrimary={{ label: 'Lancer la démo', href: APP_URL }}
    ctaSecondary={{ label: 'Nous contacter', href: '/contact' }}
  />
</BaseLayout>
