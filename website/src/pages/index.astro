---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureSection from '../components/FeatureSection.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import CTASection from '../components/CTASection.astro';

const APP_URL = 'https://newagri.qodo.ch/login';

const benefits = [
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="m3 6 6-3 6 3 6-3v15l-6 3-6-3-6 3z" /><path d="M9 3v15M15 6v15" /></svg>',
    title: 'Toutes vos parcelles sur une carte',
    description:
      'Vue satellite suisse. Vos parcelles colorées selon la culture en place. Aucun papier à sortir.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M12 20h9" /><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" /></svg>',
    title: 'Saisie en quelques secondes',
    description:
      'Notez une intervention en 3 taps depuis votre téléphone, même avec des gants.',
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M4 4h12a4 4 0 0 1 4 4v12H8a4 4 0 0 1-4-4V4z" /><path d="M4 4v16M8 8h8M8 12h8M8 16h5" /></svg>',
    title: 'Carnet des champs en règle',
    description:
      "Toutes vos interventions enregistrées et prêtes pour les contrôles. Tranquillité d'esprit.",
  },
  {
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z" /><circle cx="12" cy="12" r="3" /></svg>',
    title: 'Une vue complète de chaque parcelle',
    description:
      'Toute l\'histoire de la parcelle en un coup d\'œil : culture, interventions, rendements.',
  },
];
---

<BaseLayout
  title="NewagriQodo — Votre exploitation agricole dans une seule app"
  description="L'application des agriculteurs suisses. Voir vos parcelles sur une carte, noter vos interventions, suivre votre carnet des champs. Sur votre téléphone et au bureau."
>
  <Hero
    eyebrow="Pour les agriculteurs suisses"
    title="Votre exploitation dans une seule app"
    subtitle="Voir vos parcelles sur la carte, noter vos interventions au champ, suivre votre carnet — tout est au même endroit. Sur votre téléphone et au bureau."
    ctaPrimary={{ label: 'Essayer la démo', href: APP_URL }}
    ctaSecondary={{ label: 'Voir les fonctionnalités', href: '/fonctionnalites' }}
    screenshot={{
      src: '/screenshots/01_Hero/H1_Hero_Desktop_-_Carte_dzoome.png',
      alt: "Vue d'ensemble de l'application avec la carte des parcelles",
    }}
  />

  <FeatureGrid
    title="Ce que NewagriQodo fait pour vous"
    subtitle="Conçue avec un exploitant suisse, pour les exploitants suisses."
    features={benefits}
  />

  <FeatureSection
    eyebrow="Vos parcelles sur une carte"
    title="Comme Google Maps, mais pour votre exploitation"
    description="Vue satellite suisse. Chaque parcelle prend la couleur de sa culture du jour. Vous voyez tout d'un coup d'œil."
    bullets={[
      'Vue <strong>satellite suisse</strong> de qualité',
      "Couleurs <strong>automatiques</strong> selon ce qui pousse aujourd'hui",
      'Cliquez sur une parcelle pour voir tous ses détails',
      'Importez vos parcelles depuis <strong>GELAN</strong> ou <strong>Acorda</strong>',
    ]}
    screenshot={{
      src: '/screenshots/01_Hero/H3_Hero_Desktop_-_Panel__droite.png',
      alt: 'Carte des parcelles avec panneau de détail à droite',
    }}
  />

  {/* SECTION "SAISIE FACILE" — DÉSACTIVÉE TEMPORAIREMENT
   * En attente des vrais screenshots du formulaire InterventionForm.
   * Voir fonctionnalites.astro pour le détail. */}

  <FeatureSection
    eyebrow="Fiche parcelle complète"
    title="Toute l'histoire d'une parcelle, à portée de main"
    description="Culture en place, interventions passées, rendements, statistiques. Tout est rangé par onglets clairs, vous trouvez ce que vous cherchez en 2 secondes."
    bullets={[
      'Un <strong>résumé visuel</strong> dès l\'ouverture',
      'Onglets : Aperçu, Carnet, Assolement, Statistiques, Carte',
      '<strong>Mini-carte</strong> de la parcelle directement intégrée',
      'Lien direct pour aller au champ via <strong>Google Maps</strong>',
    ]}
    screenshot={{
      src: '/screenshots/03_DetailParcelle/D1_Detail_-_Aperu.png',
      alt: 'Fiche détaillée d\'une parcelle avec résumé et mini-carte',
    }}
  />

  <FeatureSection
    eyebrow="Carnet des champs"
    title="Vos interventions, prêtes pour les contrôles"
    description="Tout ce que vous faites sur vos parcelles est enregistré au bon format. Quand un contrôleur passe, vous avez tout sous la main."
    reverse
    bullets={[
      'Liste complète, filtrable par <strong>date, parcelle, type</strong>',
      "Numéro d'homologation des produits enregistré automatiquement",
      "Date de récolte autorisée <strong>calculée pour vous</strong> selon le délai du produit",
      'Export PDF / Excel quand vous voulez',
    ]}
    screenshot={{
      src: '/screenshots/04_Carnet/C1_Carnet_-_Table_interventions.png',
      alt: 'Liste des interventions du carnet des champs',
    }}
  />

  <section class="border-t border-(--color-border) bg-(--color-bg) px-4 py-16 sm:px-6 sm:py-20">
    <div class="mx-auto max-w-3xl rounded-(--radius-lg) border border-(--color-border) bg-(--color-surface) p-8 text-center shadow-(--shadow-card)">
      <span class="inline-block rounded-(--radius-pill) bg-(--color-accent)/10 px-3 py-1 text-xs font-semibold tracking-wider text-(--color-accent) uppercase">
        Intégration
      </span>
      <h2 class="m-0 mt-3 text-2xl font-bold sm:text-3xl">Connecté à votre Odoo</h2>
      <p class="m-0 mt-3 text-base text-(--color-muted)">
        Si vous utilisez déjà <a href="https://www.odoo.com" target="_blank" rel="noopener noreferrer" class="font-medium text-(--color-primary) hover:underline">Odoo</a>
        pour votre comptabilité ou vos employés, NewagriQodo s'y branche directement.
        Pas de double saisie : ce que vous notez ici remonte automatiquement dans votre Odoo.
      </p>
    </div>
  </section>

  <CTASection
    title="Essayez en 30 secondes"
    subtitle="Pas d'inscription, pas de carte de crédit. Vous arrivez directement sur un vrai domaine, avec de vraies parcelles."
    ctaPrimary={{ label: 'Lancer la démo', href: APP_URL }}
    ctaSecondary={{ label: 'Voir les fonctionnalités', href: '/fonctionnalites' }}
  />
</BaseLayout>
