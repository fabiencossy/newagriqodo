---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const APP_URL = 'https://newagri.qodo.ch/login';
---

<BaseLayout
  title="Tarifs"
  description="Tarifs adaptés à votre exploitation. Démo gratuite à vie, devis personnalisé sur demande."
>
  <section class="border-b border-(--color-border) bg-gradient-to-b from-(--color-bg) to-(--color-surface)/40 px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <span class="inline-block rounded-(--radius-pill) bg-(--color-primary)/10 px-3 py-1 text-xs font-semibold tracking-wider text-(--color-primary) uppercase">
        Tarifs
      </span>
      <h1 class="m-0 mt-4 text-4xl leading-tight font-extrabold tracking-tight sm:text-5xl">
        Un tarif adapté à votre exploitation
      </h1>
      <p class="m-0 mt-4 text-lg text-(--color-muted)">
        Chaque exploitation est différente. On vous propose un tarif sur mesure selon votre
        surface, le nombre d'utilisateurs et ce dont vous avez besoin.
      </p>
      <p class="m-0 mt-3 text-base text-(--color-muted)">
        La démo est <strong class="text-(--color-text)">gratuite à vie</strong>, sans inscription.
      </p>
    </div>
  </section>

  <CTASection
    title="Discutons de votre projet"
    subtitle="Un appel rapide ou un email, on prend le temps de comprendre votre besoin et on vous fait une proposition claire."
    ctaPrimary={{ label: 'Nous contacter', href: '/contact' }}
    ctaSecondary={{ label: 'Essayer la démo', href: APP_URL }}
  />
</BaseLayout>
